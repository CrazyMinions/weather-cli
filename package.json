{
  "name": "weather-cli",
  "version": "2.0.0",
  "description": "🌤️ 美化版天气查询CLI工具 - 支持高德天气API，多日预报，空气质量，24小时预报",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "weather": "dist/index.js",
    "weather-cli": "dist/index.js"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.js",
    "lint:fix": "eslint . --ext .ts,.js --fix",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build",
    "prepare": "husky",
    "release": "npm run build && npm publish"
  },
  "keywords": [
    "weather",
    "cli",
    "typescript",
    "gaode",
    "amap",
    "open-meteo",
    "forecast",
    "air-quality"
  ],
  "author": "CrazyMinions",
  "license": "MIT",
  "dependencies": {
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "gradient-string": "^3.0.0",
    "node-cache": "^5.1.2",
    "node-geocoder": "^4.4.1",
    "ora": "^9.3.0",
    "string-width": "^8.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^25.5.0",
    "@types/node-geocoder": "^4.2.6",
    "eslint": "^10.1.0",
    "globals": "^15.0.0",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.0",
    "ts-jest": "^29.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
